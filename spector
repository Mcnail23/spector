#!/bin/bash

# Spector - Command Router
VERSION="1.0.0"

# Help Menu Function
display_help() {
    echo -e "Spector - The Cloud Leak & Asset Haunter\n"
    echo "Usage: ./spector [module] [arguments]"
    echo ""
    echo "Modules:"
    echo "  s3       Run the S3 bucket enumerator (Go)"
    echo "  github   Run the GitHub secret scanner (Python)"
    echo "  report   Run the report generator (Node.js)"
    echo ""
    echo "Example: ./spector s3 --target targetcorp"
}

# Capture the first argument (the module name)
MODULE=$1

# Route the commands using a case statement
case "$MODULE" in
    s3)
        shift 
        ./modules/s3-sniper/s3-sniper "$@"
        ;;
    github)
        shift
        python3 ./modules/repo-haunter/haunter.py "$@"
        ;;
    report)
        shift
        node ./modules/reporter/report.js "$@"
        ;;
    -h|--help|"")
        display_help
        ;;
    *)
        echo "[-] Unknown module: $MODULE" >&2
        display_help
        exit 1
        ;;
esac
